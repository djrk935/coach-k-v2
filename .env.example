# PostgreSQL with pgvector — the app applies migrations/ on startup automatically.
# Local: createdb coachk  then set DATABASE_URL below (no manual psql -f needed).
DATABASE_URL=postgresql://coach:coach@localhost:5432/coachk

# Required — agent + router
ANTHROPIC_API_KEY=sk-ant-...

# Gates /api/* in production (browser lock screen + x-app-key header / iOS Settings).
APP_PASSWORD=

# Optional — only if ingesting PDFs on the server
LLAMA_CLOUD_API_KEY=

# Optional — web push nudges (generate: python -m app.gen_vapid_keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Optional — iOS APNs (paid Apple Developer + AuthKey .p8)
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_AUTH_KEY=          # PEM contents or path to AuthKey_XXX.p8
# APNS_BUNDLE_ID=com.dayan.coachk
# APNS_SANDBOX=true

# Dev only — comma-separated origins for Vite (5173). Same-origin in Docker/App Platform.
# CORS_ORIGINS=http://localhost:5173
